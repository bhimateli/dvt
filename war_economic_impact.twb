    <dashboard name='War_Eco_Story' type='storyboard'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#000000' fontname='Benton Sans Book'>From Battlefield to Bankruptcy: The Economic and Social Collapse Caused by War</run>
          </formatted-text>
        </title>
      </layout-options>
      <style>
        <style-rule element='story-point-caption'>
          <format attr='width' value='897' />
        </style-rule>
      </style>
      <size maxheight='764' maxwidth='1316' minheight='764' minwidth='1316' sizing-mode='fixed' />
      <zones>
        <zone h='100000' id='2' type-v2='layout-basic' w='100000' x='0' y='0'>
          <zone h='97906' id='1' param='vert' removable='false' type-v2='layout-flow' w='98784' x='608' y='1047'>
            <zone h='4712' id='3' type-v2='title' w='98784' x='608' y='1047' />
            <zone fixed-size='115' h='15052' id='4' is-fixed='true' paired-zone-id='5' removable='false' type-v2='flipboard-nav' w='98784' x='608' y='5759' />
            <zone h='78142' id='5' paired-zone-id='4' removable='false' type-v2='flipboard' w='98784' x='608' y='20811'>
              <flipboard active-id='6' nav-type='caption' show-nav-arrows='true'>
                <story-points>
                  <story-point caption='The data clearly shows that prolonged wars severely disrupt employment, causing large-scale job losses and weakening national economies.' captured-sheet='SideBySide' id='6' />
                  <story-point caption='The visualization compares how different forms of conflict affect household poverty levels. Larger shares indicate deeper socioeconomic damage, showing how prolonged violence weakens incomes, raises living costs, and accelerates social collapse.' captured-sheet='Pie chart' id='9' />
                  <story-point caption='The heatmap reveals a strong correlation between inflation spikes and worsening poverty, unemployment, and food insecurity during conflicts. Syria, Yemen, and Israel-Hamas show the most severe multi-dimensional economic stress, indicating cascading war-driven shocks across labor markets and household survival.&#10;' captured-sheet='HeatMap' id='10' />
                  <story-point caption='Conflicts with deeper GDP contraction generally experience higher inflation, while larger war costs intensify economic instability. The upper-left cluster highlights the most severe macroeconomic shock zones across conflict types.' captured-sheet='Bubble chart' id='11' />
                  <story-point caption='Conflict zones in the Middle East and Eastern Europe combine the highest war expenditures with the deepest GDP contractions, highlighting concentrated regions of severe macroeconomic disruption.' captured-sheet='MapChart' id='13' />
                  <story-point caption='Food insecurity rises sharply in recent conflicts, with filtering by conflict type revealing distinct humanitarian escalation patterns across war categories.' captured-sheet='LinChart' id='14' />
                  <story-point caption='Modern Middle East conflicts show poverty escalation nearly 3x higher than most historical wars, underscoring the disproportionate humanitarian cost of prolonged conflict.&#10;' captured-sheet='Bar chart' id='15' />
                  <story-point caption='Three modern conflicts drive the highest youth unemployment shock, far exceeding the average conflict impact and indicating disproportionate long-term risk for younger populations.&#10;' captured-sheet='BarChart' id='16' />
                  <story-point captured-sheet='Treemap' id='17' />
                </story-points>
              </flipboard>
            </zone>
          </zone>
          <zone-style>
            <format attr='border-color' value='#000000' />
            <format attr='border-style' value='none' />
            <format attr='border-width' value='0' />
            <format attr='margin' value='8' />
          </zone-style>
        </zone>
      </zones>
      <simple-id uuid='{4DB8B468-2334-4BEA-8E1B-BCB4D972CE78}' />
    </dashboard>
  </dashboards>
