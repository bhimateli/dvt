  <worksheets>
    <worksheet name='Bar chart'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontname='Benton Sans Book'>Top Conflicts by Poverty Increase (%)</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='war_economic_impact_dataset (war_economic_impact_dataset)' name='federated.1kom1bd1ojma851181utd04qpyoo' />
          </datasources>
          <datasource-dependencies datasource='federated.1kom1bd1ojma851181utd04qpyoo'>
            <column caption='Poverty Increase' datatype='real' name='[Calculation_2196878737620997]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[During_War_Poverty_Rate_%] - [Pre_War_Poverty_Rate_%]' />
            </column>
            <column caption='Conflict Name' datatype='string' name='[Conflict_Name]' role='dimension' type='nominal' />
